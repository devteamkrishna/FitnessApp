<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FitnessAppPro.LoginPage">

    <Grid>

        <!-- BACKGROUND IMAGES (must be first so they stay behind) -->
        <Image
            x:Name="BackgroundImageOld"
            Aspect="AspectFill"
            Opacity="0.75" />

        <Image
            x:Name="BackgroundImageNew"
            Aspect="AspectFill"
            Opacity="0" />

        <!-- OVERLAY CONTENT -->
        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            VerticalOptions="Center"
            HorizontalOptions="Center">

            <Frame BackgroundColor="#80000000"
                   CornerRadius="12"
                   Padding="20"
                   HasShadow="True"
                   WidthRequest="300"
                   HorizontalOptions="Center">

                <VerticalStackLayout Spacing="15">

                    <Label Text="Login"
                           FontSize="40"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <Entry x:Name="UsernameEntry"
                           Placeholder="Username or Email"
                           Keyboard="Email"
                           TextColor="White"
                           PlaceholderColor="LightGray"
                           BackgroundColor="Transparent"
                           HeightRequest="45" />

                    <Entry x:Name="PasswordEntry"
                           Placeholder="Password"
                           IsPassword="True"
                           TextColor="White"
                           PlaceholderColor="LightGray"
                           BackgroundColor="Transparent"
                           HeightRequest="45" />

                    <Button Text="Login"
                            BackgroundColor="#0099cc"
                            TextColor="White"
                            HeightRequest="45"
                            Clicked="LoginClicked"
                            CornerRadius="8" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
