<ContentPage
    x:Class="FitnessAppPro.Views.WorkoutsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:FitnessAppPro.Models"
    Title="Workouts">
    <ScrollView>
        <Grid>
            <Image Source="gym_background4.jpg" Aspect="AspectFill" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" />
            <Grid RowDefinitions="Auto,*" Padding="20">
                <Button
                Text="Diet Plan"
                BackgroundColor="#e5ff10"
                TextColor="Black"
                CornerRadius="18"
                HorizontalOptions="End"
                Margin="0,20,50,0"
                VerticalOptions="Start"
                Clicked="DietPlan_Clicked" />
                <Label Grid.Row="0" HorizontalOptions="Center" VerticalOptions="Start" LineBreakMode="NoWrap">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Workout" FontSize="60" FontAttributes="Bold" TextColor="White" />
                            <Span Text="Planner" FontSize="60" FontAttributes="Bold" TextColor="#e5ff10" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <CollectionView x:Name="WorkoutsCollectionView" Grid.Row="1"
                            ItemsSource="{Binding Workouts}"
                            SelectionMode="None"
                            BackgroundColor="Transparent"
                            VerticalOptions="FillAndExpand">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="35" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Workout">
                            <Frame BackgroundColor="Transparent" CornerRadius="30" HasShadow="True">
                                <StackLayout Padding="20">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackLayout Grid.Column="0">
                                            <Label Text="{Binding Name}" FontSize="25" FontAttributes="Bold" TextColor="White" />
                                            <Label Text="{Binding ShortDescription}" FontSize="20" FontAttributes="Bold" TextColor="LightSlateGrey" />
                                        </StackLayout>
                                        <Image Source="expand_icon.png"
                                           Grid.Column="1"
                                           HeightRequest="25"
                                           WidthRequest="25"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center">
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="True">
                                                    <Setter Property="Rotation" Value="180" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image" Binding="{Binding IsExpanded}" Value="False">
                                                    <Setter Property="Rotation" Value="0" />
                                                </DataTrigger>
                                            </Image.Triggers>
                                        </Image>
                                    </Grid>
                                    <StackLayout IsVisible="{Binding IsExpanded}" Spacing="12" Margin="0,20,0,0">
                                        <BoxView HeightRequest="1" BackgroundColor="Transparent" />
                                        <Label Text="Workout Details" FontSize="18" FontAttributes="Bold" TextColor="#e5ff10" HorizontalOptions="Center" />

                                        <CollectionView ItemsSource="{Binding Steps}" SelectionMode="None" BackgroundColor="Transparent">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <StackLayout Orientation="Horizontal" Spacing="5" HorizontalOptions="Center" Padding="0">
                                                        <Label Text="•" TextColor="White" FontSize="18" VerticalOptions="Start"/>
                                                        <Label Text="{Binding}" TextColor="AliceBlue" FontSize="15" LineBreakMode="WordWrap"/>
                                                    </StackLayout>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </StackLayout>
                                </StackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Workout_Tapped" />
                                </Frame.GestureRecognizers>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>